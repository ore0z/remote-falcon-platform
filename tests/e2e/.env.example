# tests/e2e/.env.local example
# Copy to .env.local and fill in real values. .env.local is gitignored.

# Mongo connection for global-setup.
# Defaults to mongodb://localhost:27017/remote-falcon when unset.
# MONGO_URI=mongodb://localhost:27017/remote-falcon

# Override the database name for smoke/regression. Has no effect on the
# docs-screenshots tier (which always targets remote-falcon-docs).
# MONGO_DATABASE=remote-falcon

# --- docs-screenshots tier (PLAYWRIGHT_TIER=docs-screenshots) ---

# Fixture user the docs-screenshots tier signs in as. Created idempotently
# by global-setup.ts via the live signUp GraphQL mutation.
DOCS_FIXTURE_USER_EMAIL=docs-demo@remotefalcon.com
DOCS_FIXTURE_USER_PASSWORD=ChangeMeForLocalDev123!

# Optional override for the control-panel GraphQL endpoint used by
# global-setup's Phase A signUp. Defaults to http://localhost:8081/graphql.
# DOCS_CONTROL_PANEL_GRAPHQL_URL=http://localhost:8081/graphql
