# DEV ONLY -- JVM build (no -Pnative).
# Build context: monorepo root. Dockerfile path: apps/external-api/Dockerfile.dev.
# See apps/control-panel/Dockerfile.dev for full rationale.

FROM maven:3-eclipse-temurin-17 AS schema-build
WORKDIR /lib
COPY libs/schema/pom.xml .
COPY libs/schema/src ./src
RUN mvn install -DskipTests -B

# libs/test-fixtures: external-api's pom.xml declares it as a test-scope dep
# (added during the RFPB integration work). Even with -Dmaven.test.skip=true,
# Maven still resolves the full dep tree at build time and fails if
# test-fixtures isn't reachable. Mirrors the same stage in apps/control-panel/
# Dockerfile.dev. Without this stage, a fresh build (no Docker layer cache)
# fails with "Could not find artifact com.remotefalcon:remote-falcon-test-
# fixtures:jar:1.0.0-LOCAL in central". Previously masked by the cache.
FROM maven:3-eclipse-temurin-17 AS test-fixtures-build
WORKDIR /lib
COPY --from=schema-build /root/.m2/repository /root/.m2/repository
COPY libs/test-fixtures/pom.xml .
COPY libs/test-fixtures/src ./src
RUN mvn install -DskipTests -B

FROM maven:3-eclipse-temurin-21 AS build
WORKDIR /usr/src/app
COPY --from=test-fixtures-build /root/.m2/repository /root/.m2/repository
COPY apps/external-api/pom.xml .
COPY apps/external-api/src ./src
RUN mvn -DskipTests package

FROM eclipse-temurin:21-jre
WORKDIR /usr/app
COPY --from=build /usr/src/app/target/remote-falcon-external-api.jar /usr/app/application.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "/usr/app/application.jar"]
