# DEV ONLY -- JVM build (no -Pnative).
# Build context: monorepo root. Dockerfile path: apps/control-panel/Dockerfile.dev.
#
# Why this variant exists:
#   GraalVM native-image for this Spring Boot app's dependency footprint
#   takes 15+ min and 12-16 GB RAM per compile. Unworkable inner-loop.
#   Prod uses the canonical Dockerfile (native).
#
# Application semantics are identical: same Java code, same classpath, same
# Spring runtime -- only cold-start and runtime memory profile differ.

FROM maven:3-eclipse-temurin-17 AS schema-build
WORKDIR /lib
COPY libs/schema/pom.xml .
COPY libs/schema/src ./src
RUN mvn install -DskipTests -B

FROM maven:3-eclipse-temurin-21 AS build
WORKDIR /usr/src/app
COPY --from=schema-build /root/.m2/repository /root/.m2/repository
COPY apps/control-panel/pom.xml .
COPY apps/control-panel/src ./src
RUN mvn -DskipTests package

FROM eclipse-temurin:21-jre
WORKDIR /usr/app
COPY --from=build /usr/src/app/target/remote-falcon-control-panel.jar /usr/app/application.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "/usr/app/application.jar"]
