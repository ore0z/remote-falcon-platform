# DEV ONLY -- Quarkus fast-jar build (no native).
# Build context: monorepo root. Dockerfile path: apps/viewer/Dockerfile.dev.
#
# Why this variant exists:
#   Native compile on aarch64 (Apple Silicon) takes 30-60+ min and can
#   deadlock GraalVM's analysis phase. Unworkable inner-loop. Prod uses
#   the canonical Dockerfile (native).
#
# Application semantics are identical: same Java code, same Quarkus runtime,
# same classpath -- only cold-start and runtime memory profile differ.

FROM maven:3-eclipse-temurin-17 AS schema-build
WORKDIR /lib
COPY libs/schema/pom.xml .
COPY libs/schema/src ./src
RUN mvn install -DskipTests -B

FROM eclipse-temurin:21-jdk AS build
WORKDIR /app
COPY --from=schema-build /root/.m2/repository /root/.m2/repository
COPY apps/viewer/. .
RUN sed -i 's/\r$//' ./gradlew && chmod +x ./gradlew

ARG MONGO_URI
ARG OTEL_URI
ENV MONGO_URI=${MONGO_URI}
ENV OTEL_URI=${OTEL_URI}

# Force jar.enabled=true even on services that disable it for native-only mode.
RUN ./gradlew clean build -x test -Dquarkus.package.jar.enabled=true

FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=build /app/build/quarkus-app /app
EXPOSE 8080
ENTRYPOINT ["java", "-Dquarkus.http.host=0.0.0.0", "-jar", "/app/quarkus-run.jar"]
