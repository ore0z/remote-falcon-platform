# Remote Falcon UI — local environment template.
# Copy to `.env.local` for local dev. All VITE_* values are baked into the
# bundle at build time, so changes require a restart of `npm run dev`.

# ---------------------------------------------------------------------------
# Design system
# ---------------------------------------------------------------------------
# Set to `true` to render the app with the v2 design system (apps/ui/STYLE_GUIDE.md).
# Default `false` keeps the legacy MUI theme. Transient flag — removed when
# the migration completes.
VITE_USE_DESIGN_SYSTEM_V2=false

# ---------------------------------------------------------------------------
# Third-party keys (production values come from CI; local dev typically OK
# with empty / dev placeholders for everything except VIEWER_JWT_KEY)
# ---------------------------------------------------------------------------
VITE_VIEWER_JWT_KEY=dev-jwt-secret-change-me
VITE_GOOGLE_MAPS_KEY=
VITE_PUBLIC_POSTHOG_KEY=
VITE_GA_TRACKING_ID=
VITE_MIXPANEL_KEY=
VITE_CLARITY_PROJECT_ID=
VITE_SOCIAL_META=
