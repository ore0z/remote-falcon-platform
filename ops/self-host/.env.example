# Remote Falcon self-host configuration.
# Copy this file to `.env` and fill in your values. Lines starting with `#`
# are comments. Anything with a sane default can be left blank.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Your public-facing URL. This is what viewers will use to reach your show
# and what the UI bundle bakes in at build time. Include the scheme.
# Examples: https://lights.example.com, https://mychristmasshow.com
WEB_URL=https://your-domain.com

# Number of dot-separated parts in your hostname. Affects how the UI extracts
# the show subdomain from the host header.
#   example.com         → 2
#   sub.example.com     → 3
HOSTNAME_PARTS=2

# JWT signing secrets. Use long random strings (32+ chars). Generate with:
#   openssl rand -base64 32
#
# - JWT_USER     — control-panel HMAC key for owner sign-in tokens. Active.
# - JWT_VIEWER   — baked into the UI bundle at build time; the UI signs
#                  viewer-side tokens with it. Currently a required build
#                  arg even though the viewer service doesn't verify it
#                  (viewer auth is host-header based via showSubdomain).
#                  Set a value anyway; rotation is a no-op until the viewer
#                  begins verifying.
#
# WARNING: changing JWT_USER after first boot invalidates existing owner
# sessions. Set once and treat as a secret.
JWT_USER=change-me-to-a-random-string
JWT_VIEWER=change-me-to-a-random-string

# ─────────────────────────────────────────────────────────────────────────────
# MONGO
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB credentials. The container creates this user on first boot and
# writes data into the `mongo-data` Docker volume. If you change these AFTER
# first boot, you'll need to drop the volume and start fresh (or update the
# Mongo user via mongosh).
MONGO_USERNAME=root
MONGO_PASSWORD=root

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — leave blank to disable the corresponding feature
# ─────────────────────────────────────────────────────────────────────────────

# Email verification. Set to false to require users to click an email link
# before they can sign in. Requires SENDGRID_KEY to send the email.
AUTO_VALIDATE_EMAIL=true

# Reverse-proxy header for client IP. If you're sitting behind Cloudflare,
# use CF-Connecting-IP. Behind plain nginx (default), X-Forwarded-For works.
CLIENT_HEADER=X-Forwarded-For

# SendGrid API key for transactional email (welcome / password reset /
# verification). Leave blank to disable email entirely. If blank, set
# AUTO_VALIDATE_EMAIL=true so users don't get stuck waiting for a verify link.
SENDGRID_KEY=

# Google Maps embed key for the "Shows Map" feature. Leave blank to disable
# the map. Hobbyist self-hosters typically don't need this.
GOOGLE_MAPS_KEY=

# PostHog product analytics. Leave blank to disable.
PUBLIC_POSTHOG_KEY=

# Google Analytics. Leave blank to disable.
GA_TRACKING_ID=

# Image hosting via S3-compatible storage. Leave blank to disable image upload.
# (Most self-hosters skip this; viewer pages with hand-written HTML don't need it.)
S3_ENDPOINT=
S3_ACCESSKEY=
S3_SECRETKEY=

# GitHub personal access token for the in-product Issues integration. Leave
# blank to disable. Read-only token is sufficient.
GITHUB_PAT=

# Jukebox sequence limit. The plugins-api enforces this when a show owner
# tries to add more active sequences. Default matches SaaS.
SEQUENCE_LIMIT=200

# Subdomain handling. If your domain has only one viewer page and you'd
# rather serve it at the root (lights.example.com) instead of
# <show>.lights.example.com, set SWAP_CP=true and put your show subdomain here.
SWAP_CP=false
VIEWER_PAGE_SUBDOMAIN=

# Version label baked into the UI bundle (shown in the avatar dropdown).
# Override to track your own build cadence; default is "self-host".
VERSION=self-host
