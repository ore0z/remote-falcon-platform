# Copy to .env.dev and fill in values you actually need for local dev.
# Most blanks are fine for the basic stack to come up — the corresponding
# integrations (email, OpenAI/Wattson, Google Maps, GitHub) just won't work
# until populated. Some values must be non-empty even in dev (called out
# in their section comments below).

# ---- shared ---------------------------------------------------------------

# Used by the UI build AND should match the value the viewer service uses to
# verify viewer-side JWTs (control-panel/viewer config).
VIEWER_JWT_KEY=dev-jwt-secret-change-me

# ---- control-panel --------------------------------------------------------

# Required at startup.
WEB_URL=http://localhost:3000
JWT_USER=dev-control-panel-jwt
CLIENT_HEADER=dev-client

# S3 must be set even in dev — S3ClientConfig.java throws
# IllegalStateException at startup if s3.endpoint is blank. Dummy values
# below let control-panel start cleanly; S3 features (image upload /
# download / delete) only break if you actually exercise them. Replace
# with real DigitalOcean Spaces creds when you need to test image flows.
# Tracked separately for proper conditional-bean cleanup.
S3_ENDPOINT=https://dev-noop.invalid
S3_ACCESSKEY=dev
S3_SECRETKEY=dev

# Optional integrations — leave blank to disable in dev. These are read
# lazily and only fail when the feature is exercised.
GITHUB_PAT=
SENDGRID_KEY=
WATTSON_KEY=
OPENAI_MODEL=gpt-4o-mini
WATTSON_MAX_OUTPUT_TOKENS=2048

# ---- mongo-backup ---------------------------------------------------------

# DigitalOcean Spaces / S3 creds for backup uploads. Leave default-dev to skip.
AWS_ACCESS_KEY_ID=dev
AWS_SECRET_ACCESS_KEY=dev
AWS_REGION=us-east-1
BACKUP_AUTH_TOKEN=dev-backup-token

# ---- ui (build-args) ------------------------------------------------------

# These are baked into the JS bundle at build time. Leave blank to disable
# the corresponding analytics integration in dev.
GOOGLE_MAPS_KEY=
PUBLIC_POSTHOG_KEY=
GA_TRACKING_ID=
MIXPANEL_KEY=
CLARITY_PROJECT_ID=
